{
  "title": "Mneme3 — 系统概览",
  "version": 1,
  "uid": "mneme3-overview",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "title": "HTTP 请求速率",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "rate(mneme_http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}}",
          "intervalFactor": 2,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "min": 0,
          "custom": {"displayMode": "table"}
        }
      }
    },
    {
      "title": "HTTP P99 延迟",
      "type": "timeseries",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(mneme_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99 - {{method}} {{route}}",
          "intervalFactor": 2,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": {"displayMode": "table"}
        }
      }
    },
    {
      "title": "HTTP 5xx 错误率",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 8},
      "targets": [
        {
          "expr": "rate(mneme_http_errors_total[5m])",
          "legendFormat": "{{method}} {{route}}",
          "intervalFactor": 2,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "errps", "min": 0}
      }
    },
    {
      "title": "请求量 (5m 累计)",
      "type": "stat",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(mneme_http_requests_total[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "color": {"mode": "fixed", "fixedColor": "blue"}}
      }
    },
    {
      "title": "错误率 (5m 累计)",
      "type": "stat",
      "gridPos": {"x": 18, "y": 4, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "sum(rate(mneme_http_errors_total[5m])) / sum(rate(mneme_http_requests_total[5m]))",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0.01, "color": "yellow"}, {"value": 0.05, "color": "red"}]}}
      }
    },
    {
      "title": "数据库",
      "type": "row",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 1},
      "collapsed": true,
      "panels": [
        {
          "title": "DB 连接池使用率",
          "type": "timeseries",
          "gridPos": {"x": 0, "y": 9, "w": 8, "h": 8},
          "targets": [
            {
              "expr": "mneme_db_pool_total_connections / mneme_db_pool_size",
              "legendFormat": "池使用率",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percentunit",
              "min": 0,
              "max": 1,
              "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0.7, "color": "yellow"}, {"value": 0.85, "color": "red"}]}
            }
          }
        },
        {
          "title": "DB 连接数",
          "type": "timeseries",
          "gridPos": {"x": 8, "y": 9, "w": 8, "h": 8},
          "targets": [
            {"expr": "mneme_db_pool_checked_in", "legendFormat": "checked_in", "refId": "A"},
            {"expr": "mneme_db_pool_checked_out", "legendFormat": "checked_out", "refId": "B"},
            {"expr": "mneme_db_pool_size", "legendFormat": "pool_size", "refId": "C"}
          ],
          "fieldConfig": {"defaults": {"min": 0}}
        },
        {
          "title": "DB 就绪状态",
          "type": "stat",
          "gridPos": {"x": 16, "y": 9, "w": 8, "h": 4},
          "targets": [
            {"expr": "mneme_db_ready", "legendFormat": "", "refId": "A"}
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "thresholds"},
              "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 0, "color": "red"}]},
              "mappings": [{"type": "value", "options": {"0": {"text": "Unavailable", "color": "red"}, "1": {"text": "Ready", "color": "green"}}}]
            }
          }
        }
      ]
    },
    {
      "title": "系统资源",
      "type": "row",
      "gridPos": {"x": 0, "y": 9, "w": 24, "h": 1},
      "collapsed": true,
      "panels": [
        {
          "title": "CPU 使用率",
          "type": "timeseries",
          "gridPos": {"x": 0, "y": 10, "w": 8, "h": 8},
          "targets": [
            {"expr": "mneme_system_cpu_usage_percent", "legendFormat": "系统 CPU", "refId": "A"},
            {"expr": "mneme_process_cpu_percent", "legendFormat": "进程 CPU", "refId": "B"}
          ],
          "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
        },
        {
          "title": "内存",
          "type": "timeseries",
          "gridPos": {"x": 8, "y": 10, "w": 8, "h": 8},
          "targets": [
            {"expr": "mneme_system_memory_used_bytes", "legendFormat": "已用", "refId": "A"},
            {"expr": "mneme_system_memory_total_bytes", "legendFormat": "总量", "refId": "B"}
          ],
          "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}}
        },
        {
          "title": "进程 RSS",
          "type": "timeseries",
          "gridPos": {"x": 16, "y": 10, "w": 8, "h": 8},
          "targets": [
            {"expr": "mneme_process_memory_rss_bytes", "legendFormat": "RSS", "refId": "A"}
          ],
          "fieldConfig": {"defaults": {"unit": "bytes", "min": 0}}
        },
        {
          "title": "系统负载 (LA)",
          "type": "timeseries",
          "gridPos": {"x": 0, "y": 18, "w": 8, "h": 8},
          "targets": [
            {"expr": "mneme_system_cpu_load_1m", "legendFormat": "1m", "refId": "A"},
            {"expr": "mneme_system_cpu_load_5m", "legendFormat": "5m", "refId": "B"},
            {"expr": "mneme_system_cpu_load_15m", "legendFormat": "15m", "refId": "C"}
          ],
          "fieldConfig": {"defaults": {"min": 0}}
        },
        {
          "title": "线程 & 文件描述符",
          "type": "timeseries",
          "gridPos": {"x": 8, "y": 18, "w": 8, "h": 8},
          "targets": [
            {"expr": "mneme_process_thread_count", "legendFormat": "线程", "refId": "A"},
            {"expr": "mneme_process_open_fds", "legendFormat": "FDs", "refId": "B"}
          ]
        },
        {
          "title": "出站事件积压",
          "type": "timeseries",
          "gridPos": {"x": 16, "y": 18, "w": 8, "h": 8},
          "targets": [
            {"expr": "mneme_outbox_pending", "legendFormat": "pending", "refId": "A"}
          ],
          "fieldConfig": {
            "defaults": {
              "min": 0,
              "thresholds": {"mode": "absolute", "steps": [{"value": null, "color": "green"}, {"value": 50, "color": "yellow"}, {"value": 100, "color": "red"}]}
            }
          }
        }
      ]
    }
  ]
}
