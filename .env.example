# ═══════════════════════════════════════════════════════════════════
# Mneme3 — Environment Variables
# ═══════════════════════════════════════════════════════════════════
# Copy to .env and modify for your environment.
# All secrets should be changed before production deployment.
# ═══════════════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────────────
MNEME_ENV=local
MNEME_LOG_LEVEL=INFO

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=mneme
POSTGRES_USER=mneme
POSTGRES_PASSWORD=mneme_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://mneme:mneme_dev_password@postgres:5432/mneme

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Session ──────────────────────────────────────────────────────
MNEME_SESSION_TTL_HOURS=24
MNEME_SESSION_COOKIE_NAME=mneme_session
MNEME_SESSION_COOKIE_SECURE=true

# ── Bootstrap Owner ──────────────────────────────────────────────
MNEME_BOOTSTRAP_OWNER_USERNAME=owner
# MNEME_BOOTSTRAP_OWNER_EMAIL=owner@example.com
# MNEME_BOOTSTRAP_OWNER_PASSWORD=change-me

# ── API Port ─────────────────────────────────────────────────────
API_PORT=8000

# ── Encryption (W3) ─────────────────────────────────────────────
# Vault Key Encryption Key (base64-encoded 256-bit key)
# Generate: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
MNEME_VAULT_KEK=

# Key storage directory (container path; docker-compose uses this)
MNEME_KEY_DIR=/mneme_data/keys

# ── NAS Storage (W3) ────────────────────────────────────────────
# NAS mount path (e.g. /mnt/nas or //192.168.1.1/share)
MNEME_NAS_PATH=

# Storage mode: local / nas / auto
MNEME_STORAGE_MODE=auto

# ── Backup ───────────────────────────────────────────────────────
MNEME_BACKUP_ROOT=/backups

# ── Watcher (W3) ─────────────────────────────────────────────────
# Watch directory for auto-import (container path; docker-compose uses this)
MNEME_WATCH_DIR=/mneme_data/watch

# Watch interval in seconds
MNEME_WATCH_INTERVAL=5

# ── Observability ────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=mneme_grafana
GRAFANA_ROOT_URL=http://localhost:3000
